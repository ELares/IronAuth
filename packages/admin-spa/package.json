{
  "name": "@ironauth/admin-spa",
  "version": "0.0.0",
  "private": true,
  "description": "The IronAuth admin console: a Preact single page app that speaks the public management API through one generated typed client.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "codegen": "openapi-typescript ../../docs/openapi/management.json -o src/api/management.gen.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build"
  },
  "dependencies": {
    "@preact/signals": "^2.0.1",
    "openapi-fetch": "^0.13.5",
    "preact": "^10.25.4",
    "preact-iso": "^2.9.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.4",
    "openapi-typescript": "^7.5.0",
    "typescript": "5.6.3",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
