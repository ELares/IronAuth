  "components": {
    "schemas": {
      "CreateEnvironmentRequest": {
        "type": "object",
        "description": "The body to create an environment under a tenant.",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "description": "The environment's display name.",
            "example": "staging"
          }
        }
      },
      "CreateManagementKeyRequest": {
        "type": "object",
        "description": "The body to mint a management API key in a `(tenant, environment)` scope.",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "description": "The key's display name.",
            "example": "ci-terraform"
          }
        }
      },
      "CreateTenantRequest": {
        "type": "object",
        "description": "The body to create a tenant. The first environment is created with it.",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "description": "The tenant's display name.",
            "example": "Acme, Inc."
          },
          "environment_display_name": {
            "type": [
              "string",
