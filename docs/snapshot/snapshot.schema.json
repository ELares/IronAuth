{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironauth.dev/schemas/config-snapshot/v1.json",
  "title": "IronAuth config snapshot",
  "description": "A canonical, deterministic, secret-free export of one environment's promotable configuration (issue #43). Two exports of the same configuration are byte-identical; no secret or key material appears. This schema is the published contract the promotion engine (issue #44) and the Terraform provider / CLI consume. The Rust validator in ironauth-store::snapshot enforces the same constraints and additionally rejects raw secret-shaped material and private JWK parameters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ironauth.config-snapshot/v1",
      "description": "The snapshot format version. An importer rejects a version it does not recognize."
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "description": "The promotable resources, keyed by resource-type wire name. Only types classified promotable (issue #41) appear: environment-identity and runtime types are excluded by construction.",
      "properties": {
        "client": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/client"
          }
        },
        "resource_server": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_server"
          }
        },
        "dcr_policy": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dcr_policy"
          }
        },
        "variable": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/variable"
          }
        }
      }
    }
  },
  "$defs": {
    "secret_reference": {
      "type": "object",
      "additionalProperties": false,
      "description": "A NAMED reference to a secret in the environment-scoped secret store. Never a secret value; import resolves it against the target environment (issue #45).",
      "required": [
        "reference"
      ],
      "properties": {
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "description": "The secret-free projection of one OAuth client. A confidential client's secret is a named reference, never inline; only PUBLIC verification keys may appear in jwks.",
      "required": [
        "client_id",
        "display_name",
        "token_endpoint_auth_method",
        "redirect_uris",
        "post_logout_redirect_uris",
        "frontchannel_logout_session_required",
        "consent_mode",
        "skip_consent",
        "store_skipped_consent",
        "require_pushed_authorization_requests",
        "require_auth_time"
      ],
      "properties": {
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "token_endpoint_auth_method": {
          "type": "string",
          "enum": [
            "client_secret_basic",
            "client_secret_post",
            "private_key_jwt",
            "client_secret_jwt",
            "none"
          ]
        },
        "redirect_uris": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "post_logout_redirect_uris": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frontchannel_logout_uri": {
          "type": "string"
        },
        "frontchannel_logout_session_required": {
          "type": "boolean"
        },
        "consent_mode": {
          "type": "string"
        },
        "skip_consent": {
          "type": "boolean"
        },
        "store_skipped_consent": {
          "type": "boolean"
        },
        "require_pushed_authorization_requests": {
          "type": "boolean"
        },
        "require_auth_time": {
          "type": "boolean"
        },
        "jwks": {
          "type": "string",
          "description": "A PUBLIC JWK Set as a JSON string. A private JWK parameter (d, p, q, dp, dq, qi, k) is rejected by the validator."
        },
        "jwks_uri": {
          "type": "string"
        },
        "token_endpoint_auth_signing_alg": {
          "type": "string"
        },
        "refresh_rotation": {
          "type": "string"
        },
        "secret": {
          "$ref": "#/$defs/secret_reference"
        }
      }
    },
    "resource_server": {
      "type": "object",
      "additionalProperties": false,
      "description": "The secret-free projection of one resource server (audience-to-format registry). No secret material.",
      "required": [
        "audience",
        "token_format"
      ],
      "properties": {
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "token_format": {
          "type": "string",
          "enum": [
            "at_jwt",
            "opaque"
          ]
        },
        "access_token_ttl_secs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dcr_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "The secret-free projection of one Dynamic Client Registration policy. No secret material.",
      "required": [
        "name",
        "primitives"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "primitives": {
          "type": "array"
        }
      }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "description": "The secret-free projection of one environment variable (issue #45): a non-secret name to value pair. A secret value never appears in a snapshot; only a variable's plain value does.",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    }
  }
}
